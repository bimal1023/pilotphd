# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pilotphd

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# JWT session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Resend (email delivery)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Brave Search (optional — used by email drafter and fellowship finder)
BRAVE_API_KEY=your-brave-api-key-here

# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# Set to "production" on Render — enables secure cookies and disables /docs
ENVIRONMENT=development

# Claude model — check https://docs.anthropic.com/en/docs/about-claude/models for the latest ID
# Snapshot versions (e.g. claude-sonnet-4-20250514) are stable but will be retired eventually
CLAUDE_MODEL=claude-sonnet-4-20250514
